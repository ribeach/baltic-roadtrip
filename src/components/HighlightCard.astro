---
interface Props {
  name: string;
  type: string;
  icon: 'star' | 'gem' | 'info';
  description: string;
  duration: string | null;
  price: string | null;
  googleMapsUrl: string;
  number?: number;
  note?: string;
}

const { name, type, icon, description, duration, price, googleMapsUrl, number, note } = Astro.props;

const iconMap = {
  star: '⭐',
  gem: '💎',
  info: 'ℹ️',
};

const typeLabels: Record<string, string> = {
  museum: 'Museum',
  nature: 'Natur',
  architecture: 'Architektur',
  market: 'Markt',
  castle: 'Burg/Schloss',
  church: 'Kirche',
  monument: 'Denkmal',
  soviet: 'Sowjet-Erbe',
  viewpoint: 'Aussichtspunkt',
  activity: 'Aktivität',
  culinary: 'Kulinarik',
};
---

<div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div class="flex items-start gap-2">
        {number && (
          <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
            {number}
          </span>
        )}
        <span class="text-xl mt-0.5">{iconMap[icon]}</span>
        <div>
          <h4 class="font-semibold text-navy-800">{name}</h4>
          <span class="text-xs text-gray-400 uppercase tracking-wide">{typeLabels[type] || type}</span>
        </div>
      </div>
    </div>
    {note && <p class="text-sm text-amber-600 italic mb-2">{note}</p>}
    <p class="text-sm text-gray-600 mb-3">{description}</p>
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3 text-xs text-gray-400">
        {duration && <span>🕐 {duration}</span>}
        {price && <span>💰 {price}</span>}
      </div>
      <a
        href={googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-xs text-amber-500 hover:text-amber-600 font-medium transition-colors"
      >
        📍 Google Maps
      </a>
    </div>
  </div>
</div>
