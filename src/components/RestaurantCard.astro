---
import RatingDisplay from './RatingDisplay.astro';

interface Props {
  name: string;
  cuisine: string;
  priceRange: string;
  description: string;
  mustTry: string | null;
  googleMapsUrl: string;
  number?: number;
  note?: string;
  rating?: number;
  userRatingCount?: number;
}

const { name, cuisine, priceRange, description, mustTry, googleMapsUrl, number, note, rating, userRatingCount } = Astro.props;
---

<div class="bg-paper rounded-xl border border-sand-200 hover:shadow-md transition-all overflow-hidden">
  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div class="flex items-start gap-2">
        {number && (
          <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
            {number}
          </span>
        )}
        <div>
        <h4 class="font-semibold text-navy-800 flex items-center gap-2">
          🍽️ {name}
        </h4>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-xs bg-sand-100 text-gray-600 px-2 py-0.5 rounded-full">{cuisine}</span>
          <span class="text-xs text-gray-400">{priceRange}</span>
          <RatingDisplay rating={rating} userRatingCount={userRatingCount} />
        </div>
      </div>
      </div>
    </div>
    {note && <p class="text-sm text-amber-600 italic mb-2">{note}</p>}
    <p class="text-sm text-gray-600 mb-2">{description}</p>
    {mustTry && (
      <p class="text-sm text-amber-600 font-medium mb-3">
        👨‍🍳 Unbedingt probieren: {mustTry}
      </p>
    )}
    <a
      href={googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-xs text-teal-600 hover:text-teal-700 font-medium transition-colors"
    >
      📍 Google Maps
    </a>
  </div>
</div>
