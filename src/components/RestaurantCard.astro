---
interface Props {
  name: string;
  cuisine: string;
  priceRange: string;
  description: string;
  mustTry: string | null;
  googleMapsUrl: string;
}

const { name, cuisine, priceRange, description, mustTry, googleMapsUrl } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow overflow-hidden">
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div>
        <h4 class="font-semibold text-navy-800 flex items-center gap-2">
          🍽️ {name}
        </h4>
        <div class="flex items-center gap-2 mt-1">
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{cuisine}</span>
          <span class="text-xs text-gray-400">{priceRange}</span>
        </div>
      </div>
    </div>
    <p class="text-sm text-gray-600 mb-2">{description}</p>
    {mustTry && (
      <p class="text-sm text-amber-600 font-medium mb-3">
        👨‍🍳 Unbedingt probieren: {mustTry}
      </p>
    )}
    <a
      href={googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-xs text-amber-500 hover:text-amber-600 font-medium transition-colors"
    >
      📍 Google Maps
    </a>
  </div>
</div>
