---
import RatingDisplay from './RatingDisplay.astro';

interface Props {
  name: string;
  description: string;
  googleMapsUrl: string;
  number?: number;
  note?: string;
  rating?: number;
  userRatingCount?: number;
  visited?: boolean;
}

const { name, description, googleMapsUrl, number, note, rating, userRatingCount, visited } = Astro.props;
---

<div class="bg-paper rounded-xl border border-sand-200 hover:shadow-md transition-all p-5">
  <div class="flex items-start justify-between gap-2">
    <div class="flex items-start gap-2">
      {number && (
        <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
          {number}
        </span>
      )}
      <h4 class="font-semibold text-navy-800">🍺 {name}</h4>
    </div>
    {visited && (
      <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium shrink-0">✓ Besucht</span>
    )}
  </div>
  {note && <p class="text-sm text-amber-600 italic mt-1">{note}</p>}
  <p class="text-sm text-gray-600 mt-1">{description}</p>
  <div class="flex items-center justify-between mt-2">
    <RatingDisplay rating={rating} userRatingCount={userRatingCount} />
    <a
      href={googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-xs text-teal-600 hover:text-teal-700 font-medium transition-colors"
    >
      📍 Google Maps
    </a>
  </div>
</div>
