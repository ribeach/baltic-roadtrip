---
import { getBase } from '../lib/content';

const base = getBase();
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}`, label: 'Route' },
  { href: `${base}kulinarik`, label: 'Kulinarik' },
  { href: `${base}praktisches`, label: 'Praktisches' },
  { href: `${base}budget`, label: 'Budget' },
];

const isActive = (href: string) => currentPath === href || currentPath === href + '/';
---

<nav class="bg-navy-800 text-white sticky top-0 z-50 shadow-lg" aria-label="Hauptnavigation">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2 font-bold text-lg hover:text-amber-400 transition-colors">
        <span class="text-2xl" aria-hidden="true">🚗⚡</span>
        <span class="hidden sm:inline">Baltikum Roadtrip</span>
        <span class="sm:hidden">Baltikum</span>
      </a>
      <div class="flex items-center gap-1 sm:gap-4">
        {links.map(link => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? 'page' : undefined}
            class:list={[
              'px-2 sm:px-3 py-2 rounded-md text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'bg-navy-600 text-amber-400'
                : 'text-gray-300 hover:text-white hover:bg-navy-700'
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>
