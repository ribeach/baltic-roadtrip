---
import BaseLayout from '../layouts/BaseLayout.astro';
import DayCard from '../components/DayCard.astro';
import RouteMap from '../components/RouteMap.tsx';
import { getCollection } from 'astro:content';
import { resolveRef, getBase } from '../lib/content';

const allDays = await getCollection('days');
const allLocations = await getCollection('locations');

const days = allDays.sort((a, b) => a.data.dayNumber - b.data.dayNumber);

const base = getBase();
const mapLocations = days
  .filter(d => d.data.driving?.mode !== 'none' || d.data.dayNumber === 1)
  .reduce((acc, day) => {
    // Insert transit waypoints (in order) before the day's main location
    for (const tRef of day.data.transitLocationIds || []) {
      const tId = resolveRef(tRef);
      const tLoc = allLocations.find(l => l.id === tId || l.data.id === tId);
      if (tLoc && !acc.find(a => a.id === tLoc.data.id)) {
        acc.push({
          id: tLoc.data.id,
          name: tLoc.data.name,
          lat: tLoc.data.coordinates.lat,
          lng: tLoc.data.coordinates.lng,
          link: `${base}tag/${day.data.dayNumber}`,
        });
      }
    }
    const locId = resolveRef(day.data.locationId);
    const loc = allLocations.find(l => l.id === locId || l.data.id === locId);
    if (loc && !acc.find(a => a.id === loc.data.id)) {
      acc.push({
        id: loc.data.id,
        name: loc.data.name,
        lat: loc.data.coordinates.lat,
        lng: loc.data.coordinates.lng,
        dayNumber: day.data.dayNumber,
        link: `${base}tag/${day.data.dayNumber}`,
      });
    }
    return acc;
  }, [] as Array<{ id: string; name: string; lat: number; lng: number; dayNumber?: number; link: string; label?: string }>);

// Close the loop: Aalen is start and end of the circular route
const aalenLoc = allLocations.find(l => l.data.id === 'aalen');
if (aalenLoc) {
  const aalenIdx = mapLocations.findIndex(loc => loc.id === 'aalen');
  if (aalenIdx !== -1) {
    mapLocations.splice(aalenIdx, 1);
  }
  const aalenBase = {
    id: 'aalen',
    name: 'Aalen (Start/Ziel)',
    lat: aalenLoc.data.coordinates.lat,
    lng: aalenLoc.data.coordinates.lng,
    link: `${base}tag/18`,
    label: '⌂',
  };
  mapLocations.unshift(aalenBase);
  mapLocations.push({ ...aalenBase, id: 'aalen-return' });
}

const routePolylines = days
  .filter(d => d.data.driving?.encodedPolyline)
  .sort((a, b) => a.data.dayNumber - b.data.dayNumber)
  .map(d => d.data.driving!.encodedPolyline!);

const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || 'DEIN_API_KEY_HIER';

const stats = [
  { value: '18', label: 'Tage' },
  { value: '10', label: 'Länder' },
  { value: '~5.500', label: 'Kilometer' },
  { value: '4', label: 'Fähren' },
  { value: '1', label: 'Elektroauto' },
];
---

<BaseLayout title="Startseite">
  <!-- Hero Section -->
  <section class="relative bg-navy-800 text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 opacity-90"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-medium text-sm uppercase tracking-widest mb-3">30. April – 17. Mai 2026</p>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-4 font-display">
          Baltikum Roadtrip
          <span class="text-amber-400"> ⚡</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-6">
          Mit dem VW ID.4 durch zehn Länder — von Prags Türmen über die Kurische Nehrung bis nach Oslo und zurück.
        </p>
        <p class="text-sm text-gray-400 flex flex-wrap gap-x-1 gap-y-1">
          {['Aalen', 'Prag', 'Warschau', 'Masuren', 'Vilnius', 'Klaipėda', 'Riga', 'Tallinn', 'Helsinki', 'Turku', 'Stockholm', 'Oslo', 'Kopenhagen', 'Berlin', 'Aalen'].map((city, i, arr) => (
            <span class="inline-flex items-center">
              <span class="bg-navy-700 px-2 py-0.5 rounded-full text-gray-300 text-xs">{city}</span>
              {i < arr.length - 1 && <span class="text-amber-400 mx-0.5">→</span>}
            </span>
          ))}
        </p>
      </div>

      <!-- Stats Bar -->
      <div class="mt-12 flex flex-wrap gap-3 max-w-3xl">
        {stats.map(stat => (
          <div class="bg-teal-600 text-white px-4 py-2 rounded-full flex items-center gap-2">
            <span class="text-lg md:text-xl font-extrabold">{stat.value}</span>
            <span class="text-xs md:text-sm text-teal-100">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Route Map -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
    <RouteMap
      client:visible
      locations={mapLocations}
      apiKey={apiKey}
      height="450px"
      polylines={routePolylines.length > 0 ? routePolylines : undefined}
    />
    <noscript>
      <div class="bg-paper rounded-xl p-8 text-center text-gray-500 border border-sand-200">
        <p>Aktiviere JavaScript, um die interaktive Karte zu sehen.</p>
        <a
          href={`https://www.google.com/maps/dir/${mapLocations.map(l => `${l.lat},${l.lng}`).join('/')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-teal-600 hover:text-teal-700 font-medium mt-2 inline-block"
        >
          Route in Google Maps öffnen →
        </a>
      </div>
    </noscript>
  </section>

  <!-- Quick Navigation -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href={`${base}kulinarik`} class="group bg-paper rounded-xl border-l-4 border-l-amber-400 border border-sand-200 p-6 hover:-translate-y-0.5 hover:shadow-md transition-all">
        <span class="text-3xl">🍽️</span>
        <h3 class="font-bold text-navy-800 mt-2 group-hover:text-teal-600 transition-colors">Kulinarischer Guide</h3>
        <p class="text-sm text-gray-500 mt-1">Must-Try-Gerichte in jedem Land</p>
      </a>
      <a href={`${base}praktisches`} class="group bg-paper rounded-xl border-l-4 border-l-teal-600 border border-sand-200 p-6 hover:-translate-y-0.5 hover:shadow-md transition-all">
        <span class="text-3xl">⚡</span>
        <h3 class="font-bold text-navy-800 mt-2 group-hover:text-teal-600 transition-colors">Praktische Infos</h3>
        <p class="text-sm text-gray-500 mt-1">E-Laden, Maut, Geschwindigkeit, Währungen</p>
      </a>
      <a href={`${base}budget`} class="group bg-paper rounded-xl border-l-4 border-l-navy-600 border border-sand-200 p-6 hover:-translate-y-0.5 hover:shadow-md transition-all">
        <span class="text-3xl">💰</span>
        <h3 class="font-bold text-navy-800 mt-2 group-hover:text-teal-600 transition-colors">Budget</h3>
        <p class="text-sm text-gray-500 mt-1">Kostenschätzung pro Person und Land</p>
      </a>
    </div>
  </section>

  <!-- Day-by-Day Timeline -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20 mb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-navy-800">Tag für Tag</h2>
      <p class="text-gray-500 mt-2">18 Tage, von Schwaben über Prag und das Baltikum bis Oslo und zurück</p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-0.5 bg-sand-300"></div>

      <div class="space-y-8">
        {days.map((day, i) => (
          <DayCard
            dayNumber={day.data.dayNumber}
            date={day.data.date}
            title={day.data.title}
            subtitle={day.data.subtitle}
            driving={day.data.driving}
            evCharging={day.data.evCharging}
            activities={day.data.activities}
            isLeft={i % 2 === 0}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
