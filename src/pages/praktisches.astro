---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCountries = await getCollection('countries');
const routeOrder = ['germany', 'poland', 'lithuania', 'latvia', 'estonia', 'finland', 'sweden', 'denmark'];
const countries = allCountries.sort((a, b) => routeOrder.indexOf(a.data.id) - routeOrder.indexOf(b.data.id));

// Usable battery capacity for 10→80% charge (kWh) — VW ID.4 (77 kWh * ~70%)
const CHARGE_KWH = 54;

const essentialApps = [
  { name: 'A Better Route Planner (ABRP)', purpose: 'Routenplanung & Verbrauch', scope: 'Alle Länder' },
  { name: 'PlugShare', purpose: 'Ladestationen finden & Erfahrungsberichte', scope: 'Alle Länder' },
  { name: 'Plugsurfing + RFID-Karte', purpose: 'Bezahlen an 940.000+ Ladepunkten', scope: 'DE, PL, Backup Baltikum' },
  { name: 'Mobilly', purpose: 'Einheitliche Bezahlung im Baltikum', scope: 'LT, LV, EE' },
  { name: 'Eleport', purpose: 'Dominanter Anbieter Baltikum + Polen', scope: 'EE, LV, LT, PL' },
  { name: 'Ignitis ON', purpose: 'QR-Code, keine Registrierung nötig', scope: 'LT, LV, EE' },
  { name: 'GreenWay', purpose: 'Polens größtes Ladenetz', scope: 'PL' },
  { name: 'IONITY', purpose: 'Schnellladen an Autobahnen', scope: 'DE, SE' },
  { name: 'Fortum Charge & Drive', purpose: '38.000+ Ladepunkte Skandinavien', scope: 'FI, SE' },
];

const ferryOptions = [
  { route: 'Tallinn → Stockholm', operator: 'Tallink (Baltic Queen)', duration: '~16–17h (Nachtfähre)', price: '285–430 € gesamt (Auto + 2 Pers. + Kabine)', note: 'Empfohlen. Fahrplan prüfen (variiert saisonal). Früh buchen!' },
  { route: 'Tallinn → Helsinki', operator: 'Tallink / Eckerö Line', duration: '2–2,5h', price: '30–60 € p.P. (Fußgänger)', note: 'Für Helsinki-Tagesausflug. 12+ Abfahrten täglich.' },
  { route: 'Helsinki → Stockholm', operator: 'Viking Line / Tallink Silja', duration: '~17h (Nachtfähre)', price: '200–350 € (Auto + Kabine)', note: 'Alternative via Finnland. Schären-Panorama.' },
  { route: 'Klaipėda → Smiltynė (Kurische Nehrung)', operator: 'Lokale Fähre', duration: '~10 Min', price: '~18 € Hin+Rück (Auto)', note: 'Alle 20–30 Min. Bezahlung am Terminal.' },
];

const evRules = [
  'Auto VOR der Fähre vollladen — kein Laden an Bord möglich',
  'Bei der Buchung Fahrzeugmaße und Kennzeichen korrekt angeben',
  'Alarmsysteme auf der Fähre deaktivieren (Seegang)',
  'Mit min. 20% SoC verladen für Ausschiffung + Fahrt zum ersten Lader',
  'Autodeck ist während der Überfahrt nicht zugänglich',
];
---

<BaseLayout title="Praktische Infos">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-navy-800">⚡ Praktische Infos</h1>
      <p class="text-lg text-gray-600 mt-2">Alles zu E-Laden, Fähren, Maut, Geschwindigkeiten und Währungen für die Route.</p>
    </div>

    <!-- Vehicle Info -->
    <section class="bg-navy-800 text-white rounded-xl p-6 mb-10">
      <h2 class="text-xl font-bold mb-3">🚗 Unser Fahrzeug</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <div class="text-amber-400 font-bold text-lg">VW ID.4</div>
          <div class="text-gray-400 text-sm">Baujahr 2021</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">77 kWh</div>
          <div class="text-gray-400 text-sm">Batteriekapazität</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">350–400 km</div>
          <div class="text-gray-400 text-sm">Reale Reichweite</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">bis 135 kW</div>
          <div class="text-gray-400 text-sm">Max. Ladeleistung (DC)</div>
        </div>
      </div>
      <p class="text-sm text-gray-400 mt-4">Tipp: Immer über das Fahrzeug-Navi zur Ladesäule navigieren — die Batterie wird thermisch vorkonditioniert für schnelleres Laden.</p>
    </section>

    <!-- EV Charging by Country -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">⚡ Ladeinfrastruktur nach Land</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <caption class="sr-only">Ladeinfrastruktur und DC-Preise nach Land</caption>
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-3 py-3 text-left rounded-tl-lg">Land</th>
              <th class="px-3 py-3 text-left">Qualität</th>
              <th class="px-3 py-3 text-left">DC-Preis/kWh</th>
              <th class="px-3 py-3 text-left">Kosten pro Ladung*</th>
              <th class="px-3 py-3 text-left rounded-tr-lg">Apps</th>
            </tr>
          </thead>
          <tbody>
            {countries.map((country, i) => (
              <tr class:list={[i % 2 === 0 ? 'bg-gray-50' : 'bg-white']}>
                <td class="px-3 py-3 font-medium text-navy-800">{country.data.flag} {country.data.name}</td>
                <td class="px-3 py-3">{country.data.evCharging.quality}</td>
                <td class="px-3 py-3">{country.data.evCharging.medianDcPrice}</td>
                <td class="px-3 py-3">{
                  (() => {
                    const priceString = country.data.evCharging.medianDcPrice.replace(/,/g, '.');
                    const prices = priceString.match(/[\d.]+/g);
                    if (prices && prices.length >= 1) {
                      const low = Math.round(parseFloat(prices[0]) * CHARGE_KWH);
                      const high = prices.length >= 2 ? Math.round(parseFloat(prices[1]) * CHARGE_KWH) : Math.round(parseFloat(prices[0]) * CHARGE_KWH);
                      return `${low}–${high} €`;
                    }
                    return '—';
                  })()
                }</td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-1">
                    {country.data.evCharging.recommendedApps.slice(0, 3).map(app => (
                      <span class="text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">{app}</span>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2">*Geschätzt für 10→80% Ladung (ca. 54 kWh). Preise variieren je nach Anbieter und Tageszeit.</p>
    </section>

    <!-- Essential Apps -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">📱 Unverzichtbare Apps</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {essentialApps.map(app => (
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-3">
            <h4 class="font-semibold text-navy-800 text-sm">{app.name}</h4>
            <p class="text-xs text-gray-500 mt-1">{app.purpose}</p>
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full mt-2 inline-block">{app.scope}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Critical Charging Notes -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🔴 Kritische Strecken</h2>
      <div class="space-y-3">
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <h3 class="font-bold text-red-800">Kurische Nehrung (Litauen)</h3>
          <p class="text-sm text-red-700 mt-1">KEINE Schnelllader auf der Nehrung — nur 11 kW AC in Nida. In Klaipėda (Renerga 120 kW, Baltijos pr. 40) auf 100% laden. Rundfahrt ~100 km, kein Problem bei voller Batterie.</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <h3 class="font-bold text-yellow-800">Danzig → Vilnius (~600 km)</h3>
          <p class="text-sm text-yellow-700 mt-1">Längste Etappe. In Danzig vollladen, Stopp am ORLEN 400 kW Hub bei Nowy Dwór Gdański, dann nochmal bei Suwałki oder Marijampolė nachladen.</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <h3 class="font-bold text-yellow-800">Vor der Fähre in Tallinn</h3>
          <p class="text-sm text-yellow-700 mt-1">Kein Laden an Bord! Auto mit min. 20% SOC verladen. Nach Ankunft in Stockholm sind Schnelllader verfügbar.</p>
        </div>
      </div>
    </section>

    <!-- Speed Limits -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🚦 Geschwindigkeitsbegrenzungen</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <caption class="sr-only">Geschwindigkeitsbegrenzungen nach Land</caption>
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-4 py-3 text-left rounded-tl-lg">Land</th>
              <th class="px-4 py-3 text-center">Innerorts</th>
              <th class="px-4 py-3 text-center">Landstraße</th>
              <th class="px-4 py-3 text-center rounded-tr-lg">Autobahn</th>
            </tr>
          </thead>
          <tbody>
            {countries.map((country, i) => (
              <tr class:list={[i % 2 === 0 ? 'bg-gray-50' : 'bg-white']}>
                <td class="px-4 py-3 font-medium text-navy-800">{country.data.flag} {country.data.name}</td>
                <td class="px-4 py-3 text-center">{country.data.driving.speedLimits.urban} km/h</td>
                <td class="px-4 py-3 text-center">{country.data.driving.speedLimits.rural} km/h</td>
                <td class="px-4 py-3 text-center">{country.data.driving.speedLimits.motorway} km/h</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2">Abblendlicht 24/7 Pflicht in allen Ländern außer Deutschland (dort nur bei schlechter Sicht). Niedrige Promillegrenzen (0,2–0,5 ‰). Estland: ZWEI Warndreiecke! Litauen: Feuerlöscher Pflicht.</p>
    </section>

    <!-- Tolls -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">💳 Maut & Gebühren</h2>
      <div class="space-y-3">
        {countries.map(country => (
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
            <h3 class="font-semibold text-navy-800">{country.data.flag} {country.data.name}</h3>
            <p class="text-sm text-gray-600 mt-1">{country.data.driving.tolls}</p>
            {country.data.driving.specialRules && (
              <p class="text-xs text-gray-400 mt-1">Besonderheit: {country.data.driving.specialRules}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Currencies -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">💶 Währungen & Zahlungsmittel</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {countries.map(country => (
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4">
            <div class="flex items-center justify-between mb-1">
              <h3 class="font-semibold text-navy-800">{country.data.flag} {country.data.name}</h3>
              <span class="text-sm font-medium text-amber-500">{country.data.currency.code}</span>
            </div>
            <p class="text-sm text-gray-600">{country.data.currency.tip}</p>
          </div>
        ))}
      </div>
      <div class="mt-4 bg-blue-50 border border-blue-200 rounded-xl p-4">
        <p class="text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Eine Wise Multi-Currency-Karte ist ideal für diese Reise. EU-Roaming greift in allen Ländern auf der Route.
        </p>
      </div>
    </section>

    <!-- Ferries -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">⛴️ Fährverbindungen</h2>
      <div class="space-y-3">
        {ferryOptions.map(ferry => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-bold text-navy-800">{ferry.route}</h3>
                <p class="text-sm text-gray-500">{ferry.operator}</p>
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm font-medium text-navy-800">{ferry.duration}</div>
                <div class="text-sm text-amber-500">{ferry.price}</div>
              </div>
            </div>
            <p class="text-xs text-gray-400 mt-2">{ferry.note}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- EV on Ferries -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🔌 E-Auto auf der Fähre</h2>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <ul class="space-y-2">
          {evRules.map(rule => (
            <li class="flex items-start gap-2 text-sm text-amber-800">
              <span class="text-amber-500 mt-0.5">⚡</span>
              <span>{rule}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Weather -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🌤️ Wetter Anfang Mai</h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <h3 class="font-semibold text-navy-800">Temperaturen</h3>
            <p class="text-sm text-gray-600">12–18°C tagsüber, 4–8°C nachts</p>
          </div>
          <div>
            <h3 class="font-semibold text-navy-800">Niederschlag</h3>
            <p class="text-sm text-gray-600">Leicht und sporadisch. Regenjacke reicht.</p>
          </div>
          <div>
            <h3 class="font-semibold text-navy-800">Tageslicht</h3>
            <p class="text-sm text-gray-600">16–17 Stunden in Tallinn! Kaum echte Dunkelheit.</p>
          </div>
        </div>
        <p class="text-sm text-gray-500 mt-4">
          <strong>Packliste:</strong> T-Shirt + Fleece + wind-/wasserdichte Außenschicht. Im Baltikum im Mai ist Layering der Schlüssel.
        </p>
      </div>
    </section>

    <!-- What to book -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">📅 Was wann buchen?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <h3 class="font-bold text-red-800 mb-2">🔴 Sofort buchen</h3>
          <ul class="space-y-1 text-sm text-red-700">
            <li>• Berlin Hotel (30.4.–1.5.)</li>
            <li>• Danzig Hotel (Majówka!)</li>
            <li>• Tallinn→Stockholm Fähre</li>
            <li>• Ertlio Namas Vilnius</li>
            <li>• Līgatne Bunker-Tour</li>
          </ul>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <h3 class="font-bold text-yellow-800 mb-2">🟡 2–4 Wochen vorher</h3>
          <ul class="space-y-1 text-sm text-yellow-700">
            <li>• Alle Baltikum-Hotels</li>
            <li>• Rataskaevu 16 Tallinn</li>
            <li>• Helsinki-Fähre</li>
          </ul>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <h3 class="font-bold text-green-800 mb-2">🟢 Ohne Buchung</h3>
          <ul class="space-y-1 text-sm text-green-700">
            <li>• Kurische Nehrung Fähre</li>
            <li>• Berg der Kreuze</li>
            <li>• Die meisten Museen</li>
            <li>• E-Laden (Pay-as-you-go)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Back -->
    <div class="pt-8 border-t border-gray-100">
      <a href={import.meta.env.BASE_URL.replace(/\/?$/, '/')} class="text-amber-500 hover:text-amber-600 font-medium transition-colors">
        ← Zurück zur Routenübersicht
      </a>
    </div>
  </div>
</BaseLayout>
