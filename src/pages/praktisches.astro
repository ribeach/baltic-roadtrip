---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBase } from '../lib/content';

const base = getBase();

const allCountries = await getCollection('countries');
const routeOrder = ['germany', 'czech-republic', 'poland', 'lithuania', 'latvia', 'estonia', 'finland', 'sweden', 'norway', 'denmark'];
const countries = allCountries.sort((a, b) => routeOrder.indexOf(a.data.id) - routeOrder.indexOf(b.data.id));

// Usable battery capacity for 10→80% charge (kWh) — VW ID.4 (77 kWh * ~70%)
const CHARGE_KWH = 54;

const essentialApps = [
  { name: 'A Better Route Planner (ABRP)', purpose: 'Routenplanung & Verbrauch', scope: 'Alle Länder', url: 'https://abetterrouteplanner.com' },
  { name: 'PlugShare', purpose: 'Ladestationen finden & Erfahrungsberichte', scope: 'Alle Länder', url: 'https://www.plugshare.com' },
  { name: 'Plugsurfing + RFID-Karte', purpose: 'Bezahlen an 940.000+ Ladepunkten', scope: 'DE, PL, Backup Baltikum', url: 'https://plugsurfing.com' },
  { name: 'Mobilly', purpose: 'Einheitliche Bezahlung im Baltikum', scope: 'LT, LV, EE', url: 'https://mobilly.lv' },
  { name: 'Eleport', purpose: 'Dominanter Anbieter Baltikum + Polen', scope: 'EE, LV, LT, PL', url: 'https://eleport.com' },
  { name: 'Ignitis ON', purpose: 'QR-Code, keine Registrierung nötig', scope: 'LT, LV, EE', url: 'https://ignitison.lt' },
  { name: 'GreenWay', purpose: 'Polens größtes Ladenetz', scope: 'PL', url: 'https://greenwaypolska.pl' },
  { name: 'IONITY', purpose: 'Schnellladen an Autobahnen', scope: 'DE, SE', url: 'https://ionity.eu' },
  { name: 'Recharge (ehem. Fortum)', purpose: '38.000+ Ladepunkte Skandinavien', scope: 'FI, SE', url: 'https://rechargeinfra.com' },
];

const ferryOptions = [
  { route: 'Tallinn → Helsinki', operators: [{ name: 'Eckerö Line', url: 'https://www.eckeroline.fi' }, { name: 'Tallink', url: 'https://www.tallink.com' }, { name: 'Viking Line', url: 'https://www.vikingline.com' }], duration: '2–2,5h', price: '50–90 € (Auto + 2 Pers.)', note: 'Autofähre nach Helsinki als Start der Finnland-Durchquerung. 12+ Abfahrten täglich, Frühfähre ~07:30 ideal. Eckerö Line oft am günstigsten.' },
  { route: 'Turku → Stockholm', operators: [{ name: 'Viking Line (Glory/Grace)', url: 'https://www.vikingline.com' }], duration: '~11h (Nachtfähre)', price: '200–350 € (Auto + 2 Pers. + Kabine)', note: 'Nachtfähre durch den Turku-Archipel (20.000 Inseln!) mit Stopp auf den Åland-Inseln. Abfahrt 20:55, Ankunft Stockholm Stadsgården 07:30. Früh buchen!' },
  { route: 'Klaipėda → Smiltynė (Kurische Nehrung)', operators: [{ name: 'Lokale Fähre' }], duration: '~10 Min', price: '~23 € Hin+Rück (Auto)', note: 'Alle 20–30 Min. Bezahlung am Terminal. E-Autos im Mai kostenlos auf der Nehrung (Neringa-Gebühr entfällt).' },
  { route: 'Rødby → Puttgarden', operators: [{ name: 'Scandlines', url: 'https://www.scandlines.de' }], duration: '~45 Min', price: '60–100 € (Auto + 2 Pers.)', note: 'Fähre von Dänemark nach Deutschland. Abfahrt alle 30 Minuten, keine Reservierung nötig. Schnellste Verbindung nach Norddeutschland/Berlin.' },
];

const evRules = [
  'Auto VOR der Fähre vollladen — Laden an Bord nur bei Viking Line evtl. möglich (vorab buchen!)',
  'Bei der Buchung Fahrzeugmaße und Kennzeichen korrekt angeben',
  'Alarmsysteme auf der Fähre deaktivieren (Seegang)',
  'Mit min. 20% SoC verladen für Ausschiffung + Fahrt zum ersten Lader',
  'Autodeck ist während der Überfahrt nicht zugänglich',
];
---

<BaseLayout title="Praktische Infos">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-navy-800">⚡ Praktische Infos</h1>
      <p class="text-lg text-gray-600 mt-2">Alles zu E-Laden, Fähren, Maut, Geschwindigkeiten und Währungen für die Route.</p>
    </div>

    <!-- Vehicle Info -->
    <section class="bg-navy-800 text-white rounded-xl p-6 mb-10">
      <h2 class="text-xl font-bold mb-3">🚗 Unser Fahrzeug</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <div class="text-amber-400 font-bold text-lg">VW ID.4</div>
          <div class="text-gray-500 text-sm">Baujahr 2021</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">77 kWh</div>
          <div class="text-gray-500 text-sm">Batteriekapazität</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">350–400 km</div>
          <div class="text-gray-500 text-sm">Reale Reichweite</div>
        </div>
        <div>
          <div class="text-amber-400 font-bold text-lg">bis 135 kW</div>
          <div class="text-gray-500 text-sm">Max. Ladeleistung (DC)</div>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-4">Tipp: Immer über das Fahrzeug-Navi zur Ladesäule navigieren — die Batterie wird thermisch vorkonditioniert für schnelleres Laden.</p>
    </section>

    <!-- EV Charging by Country -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">⚡ Ladeinfrastruktur nach Land</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <caption class="sr-only">Ladeinfrastruktur und DC-Preise nach Land</caption>
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-3 py-3 text-left rounded-tl-lg">Land</th>
              <th class="px-3 py-3 text-left">Qualität</th>
              <th class="px-3 py-3 text-left">DC-Preis/kWh</th>
              <th class="px-3 py-3 text-left">Kosten pro Ladung*</th>
              <th class="px-3 py-3 text-left rounded-tr-lg">Apps</th>
            </tr>
          </thead>
          <tbody>
            {countries.map((country, i) => (
              <tr class:list={[i % 2 === 0 ? 'bg-sand-50' : 'bg-paper']}>
                <td class="px-3 py-3 font-medium text-navy-800">{country.data.flag} {country.data.name}</td>
                <td class="px-3 py-3">{country.data.evCharging.quality}</td>
                <td class="px-3 py-3">{country.data.evCharging.medianDcPrice}</td>
                <td class="px-3 py-3">{
                  (() => {
                    const priceString = country.data.evCharging.medianDcPrice.replace(/,/g, '.');
                    const prices = priceString.match(/[\d.]+/g);
                    if (prices && prices.length >= 1) {
                      const low = Math.round(parseFloat(prices[0]) * CHARGE_KWH);
                      const high = prices.length >= 2 ? Math.round(parseFloat(prices[1]) * CHARGE_KWH) : Math.round(parseFloat(prices[0]) * CHARGE_KWH);
                      return `${low}–${high} €`;
                    }
                    return '—';
                  })()
                }</td>
                <td class="px-3 py-3">
                  <div class="flex flex-wrap gap-1">
                    {country.data.evCharging.recommendedApps.slice(0, 3).map(app => (
                      <span class="text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">{app}</span>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-2">*Geschätzt für 10→80% Ladung (ca. 54 kWh). Preise variieren je nach Anbieter und Tageszeit.</p>
    </section>

    <!-- Essential Apps -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">📱 Unverzichtbare Apps</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        {essentialApps.map(app => (
          <div class="bg-paper rounded-lg border border-sand-200 p-3">
            <h4 class="font-semibold text-sm">
              {app.url ? (
                <a href={app.url} target="_blank" rel="noopener noreferrer" class="text-navy-800 hover:text-teal-600 transition-colors">
                  {app.name} ↗
                </a>
              ) : (
                <span class="text-navy-800">{app.name}</span>
              )}
            </h4>
            <p class="text-xs text-gray-500 mt-1">{app.purpose}</p>
            <span class="text-xs bg-sand-100 text-gray-600 px-2 py-0.5 rounded-full mt-2 inline-block">{app.scope}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Critical Charging Notes -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🔴 Kritische Strecken</h2>
      <div class="space-y-3">
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <h3 class="font-bold text-red-800">Kurische Nehrung mit Übernachtung in Nida</h3>
          <p class="text-sm text-red-700 mt-1">KEINE Schnelllader auf der Nehrung — nur 11 kW AC in Nida. In Klaipėda (Renerga 120 kW, Baltijos pr. 40) auf 100% laden. Hinfahrt ~50 km, kein Problem. Über Nacht am AC-Lader in Nida hängen — reicht für die Rückfahrt nach Klaipėda. Dort Schnellladen vor der Weiterfahrt nach Riga.</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <h3 class="font-bold text-yellow-800">Masuren → Vilnius (Suwalki-Korridor)</h3>
          <p class="text-sm text-yellow-700 mt-1">In Masuren auf 80%+ laden (GreenWay in Giżycko/Mikołajki). Der Suwalki-Korridor zwischen Polen und Litauen hat lückenhafte Ladeinfrastruktur — Stopp bei Suwałki oder nach der Grenze bei Marijampolė einplanen.</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <h3 class="font-bold text-yellow-800">Vor der Fähre in Turku</h3>
          <p class="text-sm text-yellow-700 mt-1">In Turku vor dem Boarding der Viking Line voll laden (Hotel Kakola/Radisson Blu haben E-Laden, alternativ Schnelllader am Hafen). Viking Line bietet evtl. Laden an Bord (vorab anfragen!). Tallinn→Helsinki-Fähre: Auto mit min. 50% SOC verladen für die Weiterfahrt nach Turku.</p>
        </div>
      </div>
    </section>

    <!-- Speed Limits -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🚦 Geschwindigkeitsbegrenzungen</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <caption class="sr-only">Geschwindigkeitsbegrenzungen nach Land</caption>
          <thead>
            <tr class="bg-navy-800 text-white">
              <th class="px-4 py-3 text-left rounded-tl-lg">Land</th>
              <th class="px-4 py-3 text-center">Innerorts</th>
              <th class="px-4 py-3 text-center">Landstraße</th>
              <th class="px-4 py-3 text-center rounded-tr-lg">Autobahn</th>
            </tr>
          </thead>
          <tbody>
            {countries.map((country, i) => (
              <tr class:list={[i % 2 === 0 ? 'bg-sand-50' : 'bg-paper']}>
                <td class="px-4 py-3 font-medium text-navy-800">{country.data.flag} {country.data.name}</td>
                <td class="px-4 py-3 text-center">{country.data.driving.speedLimits.urban} km/h</td>
                <td class="px-4 py-3 text-center">{country.data.driving.speedLimits.rural} km/h</td>
                <td class="px-4 py-3 text-center">{typeof country.data.driving.speedLimits.motorway === 'number' ? `${country.data.driving.speedLimits.motorway} km/h` : country.data.driving.speedLimits.motorway}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-500 mt-2">Abblendlicht 24/7 Pflicht in allen Ländern außer Deutschland (dort nur bei schlechter Sicht). Niedrige Promillegrenzen (0,2–0,5 ‰). Estland: Feuerlöscher + Unterlegkeil Pflicht! Litauen: Feuerlöscher Pflicht.</p>
    </section>

    <!-- Tolls -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">💳 Maut & Gebühren</h2>
      <div class="space-y-3">
        {countries.map(country => (
          <div class="bg-paper rounded-lg border border-sand-200 p-4">
            <h3 class="font-semibold text-navy-800">{country.data.flag} {country.data.name}</h3>
            <p class="text-sm text-gray-600 mt-1">{country.data.driving.tolls}</p>
            {country.data.driving.specialRules && (
              <p class="text-xs text-gray-500 mt-1">Besonderheit: {country.data.driving.specialRules}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Parking -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🅿️ Parken in Altstädten</h2>
      <div class="space-y-3">
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">🇱🇹 Vilnius</h3>
          <p class="text-sm text-gray-600 mt-1">Altstadt weitgehend autofrei. Parkhäuser am Rand: Go9 (EV-Laden möglich), CityPark Gedimino. ~2–5 €/Std.</p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">🇱🇻 Riga</h3>
          <p class="text-sm text-gray-600 mt-1">Altstadt autofrei. Parkhäuser an der Esplanade oder Origo Center. ~2–4 €/Std.</p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">🇪🇪 Tallinn</h3>
          <p class="text-sm text-gray-600 mt-1">Altstadt komplett autofrei. Parkhaus Viru Keskus am Rand der Altstadt (überdacht, EV-Laden). ~3–5 €/Std.</p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">🇨🇿 Prag</h3>
          <p class="text-sm text-gray-600 mt-1">Strikte Parkzonen-Regelung. Blaue Zonen für Anwohner. Am besten im Hotelparkhaus oder P+R außerhalb der Innenstadt. ~3–5 €/Std.</p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">🇸🇪 Stockholm</h3>
          <p class="text-sm text-gray-600 mt-1">City-Maut (Trängselskatt, ~3–5 €). Garage Norrmalm oder Hötorget. P+R Liljeholmen als günstige Alternative.</p>
        </div>
      </div>
      <div class="mt-4 bg-blue-50 border border-blue-200 rounded-xl p-4">
        <p class="text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Beim Hotel immer nach Parkplatz und EV-Laden fragen — viele Unterkünfte haben eigene Stellplätze oder Kooperationen mit Parkhäusern.
        </p>
      </div>
    </section>

    <!-- Currencies -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">💶 Währungen & Zahlungsmittel</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {countries.map(country => (
          <div class="bg-paper rounded-lg border border-sand-200 p-4">
            <div class="flex items-center justify-between mb-1">
              <h3 class="font-semibold text-navy-800">{country.data.flag} {country.data.name}</h3>
              <span class="text-sm font-medium text-amber-500">{country.data.currency.code}</span>
            </div>
            <p class="text-sm text-gray-600">{country.data.currency.tip}</p>
          </div>
        ))}
      </div>
      <div class="mt-4 bg-blue-50 border border-blue-200 rounded-xl p-4">
        <p class="text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Eine <a href="https://wise.com" target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-700 font-medium">Wise Multi-Currency-Karte</a> ist ideal für diese Reise. EU-Roaming greift in allen Ländern auf der Route.
        </p>
        <p class="text-sm text-blue-800 mt-2">
          <strong>🏥 Versicherung:</strong> Europäische Krankenversicherungskarte (EHIC) mitnehmen — gilt in allen EU-Ländern auf der Route. Für Extras (Rücktransport, Gepäckverlust) lohnt sich eine zusätzliche Reiseversicherung.
        </p>
      </div>
    </section>

    <!-- Time Zones -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🕐 Zeitzonen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">MEZ (UTC+1)</h3>
          <p class="text-sm text-gray-600 mt-1">🇩🇪 Deutschland, 🇨🇿 Tschechien, 🇩🇰 Dänemark, 🇸🇪 Schweden, 🇳🇴 Norwegen, 🇵🇱 Polen</p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">OEZ (UTC+2)</h3>
          <p class="text-sm text-gray-600 mt-1">🇱🇹 Litauen, 🇱🇻 Lettland, 🇪🇪 Estland, 🇫🇮 Finnland</p>
        </div>
      </div>
      <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded-xl p-4">
        <p class="text-sm text-yellow-800">
          <strong>⚠️ Achtung:</strong> Beim Grenzübertritt Polen → Litauen (Tag 5) geht <strong>1 Stunde verloren</strong>. Umgekehrt gewinnt man 1 Stunde beim Wechsel von Estland/Finnland nach Schweden. Fährzeiten werden immer in lokaler Zeit des jeweiligen Hafens angegeben!
        </p>
      </div>
    </section>

    <!-- Border Crossings -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🛂 Grenzen & Einreise</h2>
      <div class="space-y-3">
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <p class="text-sm text-green-800">
            <strong>✅ Schengen-Raum:</strong> Alle Länder auf der Route sind im Schengen-Raum — keine Passkontrollen, kein Anhalten an der Grenze. Personalausweis oder Reisepass trotzdem mitführen (gesetzliche Pflicht).
          </p>
        </div>
        <div class="bg-paper rounded-lg border border-sand-200 p-4">
          <h3 class="font-semibold text-navy-800">⛴️ Fähren</h3>
          <p class="text-sm text-gray-600 mt-1">Beim Boarding gültigen Ausweis bereithalten — Fährgesellschaften führen Passagierlisten. Gilt für Tallinn→Helsinki, Turku→Stockholm und die Heimreise-Fähren.</p>
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <p class="text-sm text-yellow-800">
            <strong>⚠️ Suwałki-Korridor</strong> (Polen → Litauen, Tag 5): Erhöhte Militärpräsenz möglich (NATO-Ostflanke). Keine Einschränkungen für Reisende, aber nicht wundern über Konvois oder gelegentliche Kontrollen.
          </p>
        </div>
      </div>
    </section>

    <!-- Ferries -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">⛴️ Fährverbindungen</h2>
      <div class="space-y-3">
        {ferryOptions.map(ferry => (
          <div class="bg-paper rounded-xl border border-sand-200 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-bold text-navy-800">{ferry.route}</h3>
                <p class="text-sm text-gray-500">
                  {ferry.operators.map((op, i) => (
                    <>
                      {i > 0 && ' / '}
                      {op.url ? (
                        <a href={op.url} target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-700 font-medium">{op.name}</a>
                      ) : (
                        <span>{op.name}</span>
                      )}
                    </>
                  ))}
                </p>
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm font-medium text-navy-800">{ferry.duration}</div>
                <div class="text-sm text-amber-500">{ferry.price}</div>
              </div>
            </div>
            <p class="text-xs text-gray-500 mt-2">{ferry.note}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- EV on Ferries -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🔌 E-Auto auf der Fähre</h2>
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
        <ul class="space-y-2">
          {evRules.map(rule => (
            <li class="flex items-start gap-2 text-sm text-amber-800">
              <span class="text-amber-500 mt-0.5">⚡</span>
              <span>{rule}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Weather -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">🌤️ Wetter Anfang Mai</h2>
      <div class="bg-paper rounded-xl border border-sand-200 p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <h3 class="font-semibold text-navy-800">Temperaturen</h3>
            <p class="text-sm text-gray-600">12–18°C tagsüber, 4–8°C nachts</p>
          </div>
          <div>
            <h3 class="font-semibold text-navy-800">Niederschlag</h3>
            <p class="text-sm text-gray-600">Leicht und sporadisch. Regenjacke reicht.</p>
          </div>
          <div>
            <h3 class="font-semibold text-navy-800">Tageslicht</h3>
            <p class="text-sm text-gray-600">16–17 Stunden in Tallinn! Kaum echte Dunkelheit.</p>
          </div>
        </div>
        <p class="text-sm text-gray-500 mt-4">
          <strong>Packliste:</strong> T-Shirt + Fleece + wind-/wasserdichte Außenschicht. Im Baltikum im Mai ist Layering der Schlüssel.
        </p>
      </div>
    </section>

    <!-- What to book -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-navy-800 mb-4">📅 Was wann buchen?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <h3 class="font-bold text-red-800 mb-2">🔴 Sofort buchen</h3>
          <ul class="space-y-1 text-sm text-red-700">
            <li>• Prag Hotel (30.4.)</li>
            <li>• Warschau Hotel (1.–2.5.)</li>
            <li>• Oslo Hotel (13.–14.5.)</li>
            <li>• Viking Line Turku→Stockholm (Kabine + Auto)</li>
