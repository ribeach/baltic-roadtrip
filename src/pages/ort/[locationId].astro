---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HighlightCard from '../../components/HighlightCard.astro';
import RestaurantCard from '../../components/RestaurantCard.astro';
import HotelCard from '../../components/HotelCard.astro';
import ApartmentCard from '../../components/ApartmentCard.astro';
import NightlifeCard from '../../components/NightlifeCard.astro';
import TipBadge from '../../components/TipBadge.astro';
import RouteMap from '../../components/RouteMap.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(loc => ({
    params: { locationId: loc.data.id },
    props: { location: loc.data },
  }));
}

import { getBase, resolveRef, collectLocationPois, deduplicateMapPois } from '../../lib/content';

const { location } = Astro.props;
const base = getBase();
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || 'DEIN_API_KEY_HIER';

const allCountries = await getCollection('countries');
const country = allCountries.find(c => c.data.id === location.country);

const languageNames: Record<string, string> = {
  estonia: 'Estnisch',
  latvia: 'Lettisch',
  lithuania: 'Litauisch',
  finland: 'Finnisch',
  sweden: 'Schwedisch',
  norway: 'Norwegisch',
  denmark: 'Dänisch',
  poland: 'Polnisch',
  'czech-republic': 'Tschechisch',
  germany: 'Deutsch',
};
const languageName = country ? languageNames[country.data.id] ?? 'der Landessprache' : 'der Landessprache';

// Find which days reference this location
const allDays = await getCollection('days');
const assignedDays = allDays
  .filter(d =>
    resolveRef(d.data.locationId) === location.id
    || (d.data.additionalLocationIds || []).some((ref: any) => resolveRef(ref) === location.id)
    || (d.data.transitLocationIds || []).some((ref: any) => resolveRef(ref) === location.id)
  )
  .sort((a, b) => a.data.dayNumber - b.data.dayNumber);

const mapLocations = [{
  id: location.id,
  name: location.name,
  lat: location.coordinates.lat,
  lng: location.coordinates.lng,
  placeId: location.placeId,
}];

const pois = deduplicateMapPois(collectLocationPois(location));

// Derive location type tags from existing data
const tags: Array<{ label: string; color: string }> = [];
if (location.hotels.length > 0) tags.push({ label: 'Übernachtung', color: 'bg-teal-600 text-white' });
if (location.apartments.length > 0) tags.push({ label: 'Ferienwohnung', color: 'bg-purple-600 text-white' });
if (location.highlights.some((h: any) => h.type === 'nature')) tags.push({ label: 'Natur', color: 'bg-green-100 text-green-800' });
if (location.restaurants.length > 0) tags.push({ label: 'Einkehr', color: 'bg-amber-100 text-amber-800' });
if (location.highlights.some((h: any) => h.type === 'museum')) tags.push({ label: 'Kultur', color: 'bg-purple-100 text-purple-800' });
if (location.highlights.some((h: any) => h.type === 'activity')) tags.push({ label: 'Aktiv', color: 'bg-blue-100 text-blue-800' });
if (location.nightlife && location.nightlife.length > 0) tags.push({ label: 'Abends', color: 'bg-indigo-100 text-indigo-800' });
if (location.id === 'halmstad') tags.push({ label: 'Remote Work', color: 'bg-navy-600 text-white' });
---

<BaseLayout title={location.name}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href={`${base}orte`} class="hover:text-teal-600 transition-colors">Orte</a>
      <span>/</span>
      <span class="text-navy-800 font-medium">{location.name}</span>
    </div>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        {country && <span class="text-3xl">{country.data.flag}</span>}
        <div>
          <h1 class="text-3xl md:text-4xl font-extrabold text-navy-800">{location.name}</h1>
          {country && <p class="text-gray-500">{country.data.name}</p>}
        </div>
      </div>
      <p class="text-lg text-gray-600 mt-3">{location.description}</p>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map(tag => (
            <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${tag.color}`}>{tag.label}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Assigned days info -->
    {assignedDays.length > 0 && (
      <div class="mb-6 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 flex items-center gap-3 text-sm">
        <span class="text-amber-600 font-medium">📅 Eingeplant:</span>
        <div class="flex flex-wrap gap-2">
          {assignedDays.map(d => (
            <a href={`${base}tag/${d.data.dayNumber}`} class="text-amber-700 hover:text-teal-600 transition-colors font-medium">
              Tag {d.data.dayNumber}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Map -->
    <div class="mb-10">
      <RouteMap
        client:visible
        locations={mapLocations}
        pois={pois}
        apiKey={apiKey}
        height="500px"
      />
      <noscript>
        <div class="bg-paper rounded-xl p-6 text-center text-gray-600 border border-sand-200">
          <p>Aktiviere JavaScript, um die interaktive Karte zu sehen.</p>
          <a href={`https://www.google.com/maps/search/?api=1&query=${location.coordinates.lat},${location.coordinates.lng}`} target="_blank" rel="noopener noreferrer" class="text-teal-600 hover:text-teal-700 font-medium mt-2 inline-block">Karte in Google Maps öffnen →</a>
        </div>
      </noscript>
    </div>

    <!-- Tips -->
    {location.tips.length > 0 && (
      <div class="mb-10 space-y-3">
        {location.tips.map(tip => (
          <TipBadge type={tip.type} text={tip.text} />
        ))}
      </div>
    )}

    <!-- Useful local phrases -->
    {country && country.data.phrases && country.data.phrases.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">🗣️ Nützliche Wörter auf {languageName}</h2>
        <div class="bg-paper rounded-xl border border-sand-200 overflow-hidden">
          <ul class="divide-y divide-sand-200">
            {country.data.phrases.map(p => (
              <li class="grid grid-cols-1 sm:grid-cols-3 gap-1 sm:gap-4 px-4 py-3">
                <span class="text-gray-600 text-sm">{p.de}</span>
                <span class="font-semibold text-navy-800">{p.local}</span>
                <span class="text-gray-500 text-sm italic">[{p.pronunciation}]</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Highlights -->
    {location.highlights.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">⭐ Sehenswürdigkeiten & Aktivitäten</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location.highlights.map(h => (
            <HighlightCard
              name={h.name}
              type={h.type}
              icon={h.icon}
              description={h.description}
              duration={h.duration}
              price={h.price}
              googleMapsUrl={h.googleMapsUrl}
              rating={h.rating}
              userRatingCount={h.userRatingCount}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Restaurants -->
    {location.restaurants.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">🍽️ Restaurants</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location.restaurants.map(r => (
            <RestaurantCard
              name={r.name}
              cuisine={r.cuisine}
              priceRange={r.priceRange}
              isSplurge={r.isSplurge}
              description={r.description}
              mustTry={r.mustTry}
              googleMapsUrl={r.googleMapsUrl}
              rating={r.rating}
              userRatingCount={r.userRatingCount}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Hotels -->
    {location.hotels.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">🏨 Unterkünfte</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location.hotels.map(h => (
            <HotelCard
              name={h.name}
              type={h.type}
              priceRange={h.priceRange}
              isSplurge={h.isSplurge}
              evCharging={h.evCharging}
              description={h.description}
              googleMapsUrl={h.googleMapsUrl}
              rating={h.rating}
              userRatingCount={h.userRatingCount}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Apartments -->
    {location.apartments.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">🏠 Ferienwohnungen & Apartments</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location.apartments.map(a => (
            <ApartmentCard
              name={a.name}
              type={a.type}
              priceRange={a.priceRange}
              isSplurge={a.isSplurge}
              bedrooms={a.bedrooms}
              description={a.description}
              source={a.source}
              bookingUrl={a.bookingUrl}
              googleMapsUrl={a.googleMapsUrl}
              rating={a.rating}
              userRatingCount={a.userRatingCount}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Nightlife -->
    {location.nightlife && location.nightlife.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-navy-800 mb-4">🍸 Abends ausgehen</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location.nightlife.map(bar => (
            <NightlifeCard
              name={bar.name}
              description={bar.description}
              googleMapsUrl={bar.googleMapsUrl}
              rating={bar.rating}
              userRatingCount={bar.userRatingCount}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Back -->
    <div class="pt-8 border-t border-sand-200">
      <a href={`${base}orte`} class="text-teal-600 hover:text-teal-700 font-medium transition-colors">
        ← Zurück zur Orteübersicht
      </a>
    </div>
  </div>
</BaseLayout>
