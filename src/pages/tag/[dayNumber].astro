---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EvIndicator from '../../components/EvIndicator.astro';
import HighlightCard from '../../components/HighlightCard.astro';
import RestaurantCard from '../../components/RestaurantCard.astro';
import NightlifeCard from '../../components/NightlifeCard.astro';
import RouteMap from '../../components/RouteMap.tsx';
import { getCollection } from 'astro:content';
import { resolveRef, getBase, collectLocationPois, deduplicateMapPois } from '../../lib/content';

export async function getStaticPaths() {
  const days = await getCollection('days');
  return days.map(day => ({
    params: { dayNumber: String(day.data.dayNumber) },
    props: { day: day.data },
  }));
}

const { day } = Astro.props;
const base = getBase();
const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || 'DEIN_API_KEY_HIER';

const allLocations = await getCollection('locations');
const allDays = await getCollection('days');

const findLoc = (refVal: string) => allLocations.find(l => l.id === refVal || l.data.id === refVal);

const location = findLoc(resolveRef(day.locationId));
const prevLocation = day.previousLocationId ? findLoc(resolveRef(day.previousLocationId)) : null;

const additionalLocationRefs = day.additionalLocationIds || [];
const additionalLocations = additionalLocationRefs
  .map((ref) => findLoc(resolveRef(ref)))
  .filter(Boolean);

const transitLocationRefs = day.transitLocationIds || [];
const transitLocations = transitLocationRefs
  .map((ref: any) => findLoc(resolveRef(ref)))
  .filter(Boolean);

const prevDay = allDays.find(d => d.data.dayNumber === day.dayNumber - 1);
const nextDay = allDays.find(d => d.data.dayNumber === day.dayNumber + 1);

const dateObj = new Date(day.date);
dateObj.setHours(12);
const formattedDate = dateObj.toLocaleDateString('de-DE', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

const modeIcon = day.driving?.mode === 'ferry' ? '⛴️' : day.driving?.mode === 'drive' ? '🚗' : '📍';

// Build lookup maps from all locations visited this day
const allHighlights = new Map<string, { name: string; type: string; icon: 'star' | 'gem' | 'info'; description: string; duration: string | null; price: string | null; googleMapsUrl: string; placeId: string; coordinates: { lat: number; lng: number } }>();
const allRestaurants = new Map<string, { name: string; cuisine: string; priceRange: string; description: string; mustTry: string | null; googleMapsUrl: string; placeId: string; coordinates: { lat: number; lng: number } }>();
const allNightlife = new Map<string, { name: string; description: string; googleMapsUrl: string; placeId: string; coordinates: { lat: number; lng: number } }>();
for (const loc of [location, ...additionalLocations].filter(Boolean)) {
  for (const h of loc!.data.highlights) {
    allHighlights.set(h.name, h);
  }
  for (const r of loc!.data.restaurants) {
    allRestaurants.set(r.name, r);
  }
  for (const n of (loc!.data.nightlife || [])) {
    allNightlife.set(n.name, n);
  }
}

// Build POIs from ALL categories of all locations visited this day
const dayPois = deduplicateMapPois(
  [location, ...additionalLocations]
    .filter(Boolean)
    .flatMap(loc => collectLocationPois(loc!.data))
);

const mapLocations = [];
if (prevLocation) {
  mapLocations.push({
    id: prevLocation.data.id,
    name: prevLocation.data.name,
    lat: prevLocation.data.coordinates.lat,
    lng: prevLocation.data.coordinates.lng,
  });
}
// Insert transit waypoints between previous and current location
for (const tLoc of transitLocations) {
  if (!mapLocations.find(m => m.id === tLoc!.data.id)) {
    mapLocations.push({
      id: tLoc!.data.id,
      name: tLoc!.data.name,
      lat: tLoc!.data.coordinates.lat,
      lng: tLoc!.data.coordinates.lng,
    });
  }
}
if (location) {
  mapLocations.push({
    id: location.data.id,
    name: location.data.name,
    lat: location.data.coordinates.lat,
    lng: location.data.coordinates.lng,
  });
}
// Add additional locations (side trips)
for (const aLoc of additionalLocations) {
  if (!mapLocations.find(m => m.id === aLoc!.data.id)) {
    mapLocations.push({
      id: aLoc!.data.id,
      name: aLoc!.data.name,
      lat: aLoc!.data.coordinates.lat,
      lng: aLoc!.data.coordinates.lng,
    });
  }
}

const isDrivingDay = day.driving && day.driving.mode !== 'none' && mapLocations.length > 1;
const showCityMap = !isDrivingDay && location;
const cityMapLocations = showCityMap ? [{
  id: location!.data.id,
  name: location!.data.name,
  lat: location!.data.coordinates.lat,
  lng: location!.data.coordinates.lng,
}] : [];
---

<BaseLayout title={`Tag ${day.dayNumber}: ${day.title}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-gray-400 mb-6">
      <a href={base} class="hover:text-amber-500 transition-colors">Route</a>
      <span>/</span>
      <span class="text-navy-800 font-medium">Tag {day.dayNumber}</span>
    </div>

    <!-- Day Header -->
    <div class="bg-navy-800 text-white rounded-xl p-6 md:p-8 mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-amber-400 text-navy-800 font-bold text-xl w-12 h-12 rounded-full flex items-center justify-center">
          {day.dayNumber}
        </span>
        <div>
          <p class="text-amber-400 text-sm font-medium">{formattedDate}</p>
          <h1 class="text-2xl md:text-3xl font-extrabold">{day.title}</h1>
        </div>
      </div>
      <p class="text-gray-300 text-lg">{day.subtitle}</p>

      {day.driving && day.driving.mode !== 'none' && (
        <div class="mt-4 flex items-center gap-4 text-sm">
          <span class="flex items-center gap-2 bg-navy-700 px-3 py-1.5 rounded-lg">
            {modeIcon} <span class="font-medium">{day.driving.distance}</span>
          </span>
          <span class="flex items-center gap-2 bg-navy-700 px-3 py-1.5 rounded-lg">
            🕐 <span class="font-medium">{day.driving.duration}h Fahrzeit</span>
          </span>
        </div>
      )}
    </div>

    <!-- Map (driving day with route) -->
    {isDrivingDay && (
      <div class="mb-8">
        <RouteMap
          client:visible
          locations={mapLocations}
          pois={dayPois}
          apiKey={apiKey}
          height="300px"
          polylines={day.driving?.encodedPolyline ? [day.driving.encodedPolyline] : undefined}
        />
        <noscript>
          <div class="bg-gray-100 rounded-xl p-6 text-center text-gray-600">
            <p>Aktiviere JavaScript, um die interaktive Karte zu sehen.</p>
            <a href={`https://www.google.com/maps/dir/${mapLocations.map(l => `${l.lat},${l.lng}`).join('/')}`} target="_blank" rel="noopener noreferrer" class="text-amber-500 hover:text-amber-600 font-medium mt-2 inline-block">Route in Google Maps öffnen →</a>
          </div>
        </noscript>
      </div>
    )}

    <!-- Map (stationary / city day with highlights) -->
    {showCityMap && dayPois.length > 0 && (
      <div class="mb-8">
        <RouteMap
          client:visible
          locations={cityMapLocations}
          pois={dayPois}
          apiKey={apiKey}
          height="300px"
        />
        <noscript>
          <div class="bg-gray-100 rounded-xl p-6 text-center text-gray-600">
            <p>Aktiviere JavaScript, um die interaktive Karte zu sehen.</p>
            <a href={`https://www.google.com/maps/search/?api=1&query=${location!.data.coordinates.lat},${location!.data.coordinates.lng}`} target="_blank" rel="noopener noreferrer" class="text-amber-500 hover:text-amber-600 font-medium mt-2 inline-block">Karte in Google Maps öffnen →</a>
          </div>
        </noscript>
      </div>
    )}

    <!-- Driving Route -->
    {day.driving && day.driving.mode !== 'none' && (
      <div class="bg-gray-50 rounded-xl p-6 mb-8">
        <h2 class="font-bold text-navy-800 text-lg mb-2">🛣️ Strecke</h2>
        <p class="text-gray-600">{day.driving.routeDescription}</p>
      </div>
    )}

    <!-- EV Charging -->
    {day.evCharging && (
      <div class="mb-8">
        <h2 class="font-bold text-navy-800 text-lg mb-3">⚡ Ladestrategie</h2>
        <EvIndicator level={day.evCharging.criticalLevel} />
        <p class="text-sm text-gray-600 mt-2">{day.evCharging.notes}</p>
        {day.evCharging.stopsNeeded > 0 && (
          <p class="text-sm text-gray-500 mt-1">
            Geplante Ladestopps: <strong>{day.evCharging.stopsNeeded}</strong>
          </p>
        )}
      </div>
    )}

    <!-- Activities -->
    <div class="mb-8">
      <h2 class="font-bold text-navy-800 text-lg mb-3">📋 Tagesplan</h2>
      <div class="space-y-3">
        {day.activities.map((activity, i) => {
          if (typeof activity === 'string') {
            return (
              <div class="flex items-start gap-3 bg-white rounded-lg p-3 border border-gray-100">
                <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  {i + 1}
                </span>
                <p class="text-gray-700">{activity}</p>
              </div>
            );
          }
          if ('highlightRef' in activity) {
            const highlight = allHighlights.get(activity.highlightRef);
            if (!highlight) {
              return (
                <div class="flex items-start gap-3 bg-white rounded-lg p-3 border border-gray-100">
                  <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    {i + 1}
                  </span>
                  <p class="text-gray-700">{activity.highlightRef}</p>
                </div>
              );
            }
            return (
              <HighlightCard
                name={highlight.name}
                type={highlight.type}
                icon={highlight.icon}
                description={highlight.description}
                duration={highlight.duration}
                price={highlight.price}
                googleMapsUrl={highlight.googleMapsUrl}
                number={i + 1}
                note={activity.note}
              />
            );
          }
          if ('restaurantRef' in activity) {
            const restaurant = allRestaurants.get(activity.restaurantRef);
            if (!restaurant) {
              return (
                <div class="flex items-start gap-3 bg-white rounded-lg p-3 border border-gray-100">
                  <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    {i + 1}
                  </span>
                  <p class="text-gray-700">{activity.restaurantRef}</p>
                </div>
              );
            }
            return (
              <RestaurantCard
                name={restaurant.name}
                cuisine={restaurant.cuisine}
                priceRange={restaurant.priceRange}
                description={restaurant.description}
                mustTry={restaurant.mustTry}
                googleMapsUrl={restaurant.googleMapsUrl}
                number={i + 1}
                note={activity.note}
              />
            );
          }
          if ('nightlifeRef' in activity) {
            const bar = allNightlife.get(activity.nightlifeRef);
            if (!bar) {
              return (
                <div class="flex items-start gap-3 bg-white rounded-lg p-3 border border-gray-100">
                  <span class="bg-amber-400 text-navy-800 font-bold text-xs w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    {i + 1}
                  </span>
                  <p class="text-gray-700">{activity.nightlifeRef}</p>
                </div>
              );
            }
            return (
              <NightlifeCard
                name={bar.name}
                description={bar.description}
                googleMapsUrl={bar.googleMapsUrl}
                number={i + 1}
                note={activity.note}
              />
            );
          }
        })}
      </div>
    </div>

    <!-- Location cards -->
    {(location?.data.highlights.length > 0 || additionalLocations.length > 0) && (
      <div class="mb-8">
        <h2 class="font-bold text-navy-800 text-lg mb-3">📍 Orte an diesem Tag</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {location && location.data.highlights.length > 0 && (
            <a href={`${base}ort/${location.data.id}`}
               class="block bg-amber-50 border border-amber-200 rounded-xl p-5 hover:bg-amber-100 transition-colors">
              <span class="text-xs bg-amber-200 text-amber-800 font-medium px-2 py-0.5 rounded-full">Tagesziel</span>
              <h3 class="font-bold text-navy-800 mt-2">{location.data.name}</h3>
              <p class="text-sm text-gray-600 mt-1 line-clamp-2">{location.data.description}</p>
              <span class="text-amber-500 font-medium text-sm mt-2 inline-block">Details →</span>
            </a>
          )}
          {additionalLocations.map(loc => loc && (
            <a href={`${base}ort/${loc.data.id}`}
               class="block bg-gray-50 border border-gray-200 rounded-xl p-5 hover:bg-gray-100 transition-colors">
              <span class="text-xs bg-gray-200 text-gray-700 font-medium px-2 py-0.5 rounded-full">Unterwegs</span>
              <h3 class="font-bold text-navy-800 mt-2">{loc.data.name}</h3>
              <p class="text-sm text-gray-600 mt-1 line-clamp-2">{loc.data.description}</p>
              <span class="text-amber-500 font-medium text-sm mt-2 inline-block">Details →</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Navigation -->
    <div class="flex items-center justify-between pt-8 border-t border-gray-100">
      {prevDay ? (
        <a href={`${base}tag/${prevDay.data.dayNumber}`} class="flex items-center gap-2 text-navy-800 hover:text-amber-500 transition-colors">
          <span>←</span>
          <div>
            <div class="text-xs text-gray-400">Tag {prevDay.data.dayNumber}</div>
            <div class="font-medium text-sm">{prevDay.data.title}</div>
          </div>
        </a>
      ) : <div />}
      {nextDay ? (
        <a href={`${base}tag/${nextDay.data.dayNumber}`} class="flex items-center gap-2 text-right text-navy-800 hover:text-amber-500 transition-colors">
          <div>
            <div class="text-xs text-gray-400">Tag {nextDay.data.dayNumber}</div>
            <div class="font-medium text-sm">{nextDay.data.title}</div>
          </div>
          <span>→</span>
        </a>
      ) : <div />}
    </div>
  </div>
</BaseLayout>
